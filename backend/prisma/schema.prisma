generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Form {
  id             Int              @id @default(autoincrement())
  name           String
  description    String?
  is_active      Boolean          @default(true)
  created_at     DateTime         @default(now())
  updated_at     DateTime
  FormField      FormField[]
  FormSubmission FormSubmission[]
}

model FormField {
  id          Int      @id @default(autoincrement())
  form_id     Int
  name        String
  label       String
  dataType    String
  placeholder String?
  help_text   String?
  options     Json?
  validation  Json?
  is_required Boolean  @default(false)
  position    Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime
  Form        Form     @relation(fields: [form_id], references: [id], onDelete: Cascade)
}

model FormSubmission {
  id          Int      @id @default(autoincrement())
  form_id     Int
  data        Json
  created_ats DateTime @default(now())
  updated_at  DateTime
  Form        Form     @relation(fields: [form_id], references: [id], onDelete: Cascade)
}
